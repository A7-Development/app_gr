# ---------- App ----------
APP_ENV=development
LOG_LEVEL=INFO

# ---------- Postgres (gr_db) ----------
DATABASE_URL=postgresql+asyncpg://gr_app:senha@host:5432/gr_db
DATABASE_ECHO=false

# ---------- JWT ----------
# Gere uma chave forte: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000

# ---------- Bitfin (SQL Server) ----------
# Usado pelo adapter `integracoes/adapters/erp/bitfin` a partir do Sprint 2/3
BITFIN_HOST=192.168.100.16
BITFIN_DATABASE=UNLTD_A7CREDIT
BITFIN_USER=sa
BITFIN_PASSWORD=CHANGE_ME
BITFIN_DRIVER=ODBC Driver 17 for SQL Server
