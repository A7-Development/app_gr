# ---------- App ----------
APP_ENV=development
LOG_LEVEL=INFO

# ---------- Postgres (gr_db) ----------
DATABASE_URL=postgresql+asyncpg://gr_app:senha@host:5432/gr_db
DATABASE_ECHO=false

# Para pytest, aponte DATABASE_URL para gr_db_test (banco isolado, schema sincronizado
# via alembic). O guard em tests/conftest.py::pytest_configure aborta se o nome do
# banco nao contiver "test". Setup local:
#   1) CREATE DATABASE gr_db_test OWNER gr_app;
#   2) DATABASE_URL=...gr_db_test alembic upgrade head
#   3) DATABASE_URL=...gr_db_test pytest

# ---------- JWT ----------
# Gere uma chave forte: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000

# ---------- Frontend (para montar links de convite) ----------
# Base URL do frontend, sem barra final. Usada para montar a URL de aceite de
# convite ({APP_BASE_URL}/invitations/{token}). Em dev: http://localhost:3000;
# em prod: https://app.strataai.com.br. Se nao setado, cai no default localhost
# e os links de convite saem apontando para localhost (bug).
APP_BASE_URL=http://localhost:3000

# ---------- Integracoes: criptografia de secrets ----------
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_CONFIG_KEK=CHANGE_ME_TO_A_FERNET_KEY_URLSAFE_B64

# ---------- QiTech webhook ----------
# Base URL publica onde a QiTech bate o callback de relatorios async
# (familia /v2/queue/scheduler/report/*). Em prod aponta para o subdominio
# dedicado servido por Caddy/nginx → uvicorn da API GR.
# Em dev: usar ngrok / webhook.site para tunelar pro uvicorn local.
# Vazia em prod = request_fidc_estoque_report levanta QiTechAdapterError.
QITECH_WEBHOOK_BASE_URL=https://callback.strataai.com.br

# HMAC-SHA256 secret para assinar o ?token=... no callbackUrl outbound.
# A QiTech NAO assina callbacks (validado 2026-04-25), entao usamos esse
# secret pra detectar callbacks spoofados por terceiros que descubram a URL.
# Em DEV pode ficar vazio (token sai vazio, receiver aceita).
# Em PROD e OBRIGATORIO. Gerar com:
#   python -c "import secrets; print(secrets.token_hex(32))"
QITECH_WEBHOOK_SECRET=

# ---------- System health (monitoramento externo) ----------
# Bearer token para endpoints publicos de monitoramento operacional
# (/api/v1/system/endpoint-sync-status). Permite que rotinas /schedule no
# Anthropic Cloud (sem VPN) ou uptime monitors externos validem se o
# dispatcher esta sincronizando como esperado, sem precisar de JWT de
# usuario. Vazio = endpoint retorna 503. Gerar com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Em PROD: setar e nao versionar. Tratar como secret.
SYSTEM_HEALTH_TOKEN=

# ---------- Scheduler ----------
# Cadencia de sincronizacao por fonte vive em tenant_source_config.sync_frequency_minutes
# (editavel por tenant via /integracoes/catalogo/<source>). Dispatcher tica a
# cada minuto e respeita o intervalo configurado por linha.
#
# APP_SCHEDULER: liga/desliga o APScheduler no startup do FastAPI.
#   - Em dev local, recomendado `off` — sync contra Bitfin/QiTech consome
#     credenciais reais e mantem threads sync (pyodbc/httpx) ocupados, o que
#     ja causou deadlock no shutdown do uvicorn --reload (worker preso em
#     `executor.shutdown(wait=True)` durante restart).
#   - Em prod (systemd) deixe `on` (default) — sem scheduler nao ha sync.
#   - Para teste manual de uma sync sob demanda em dev, use o endpoint admin
#     POST /api/v1/integracoes/sources/{source_type}/sync (passa por
#     `run_sync_one`, que ja respeita timeouts + carimbo started_at).
APP_SCHEDULER=off

# ---------- Credito: storage de anexos do dossie ----------
# Diretorio raiz onde os blobs de anexos do dossie sao gravados:
#   <root>/<tenant_id>/<dossier_id>/<sha256[:2]>/<sha256>
# Em dev: ./storage/dossier-attachments. Em prod: caminho absoluto fora do repo.
# Migracao para S3 fica em Fase 2 (swap implementacao do StorageBackend).
DOSSIER_STORAGE_ROOT=./storage/dossier-attachments
# Limite por upload em bytes (default 25 MB).
DOSSIER_ATTACHMENT_MAX_BYTES=26214400

# ---------- Landing zone de arquivos (filedrop / Strata Collector) ----------
# Object storage canonico dos arquivos externos (CNAB, XMLs operacionais,
# uploads). Backend: `local` (disco; dev e fallback) ou `s3` (prod).
# Key layout: <tenant_id>/<ua|sem-ua>/<source_label>/<yyyy>/<mm>/<sha256>
FILE_STORAGE_BACKEND=local
FILE_STORAGE_LOCAL_ROOT=./storage/filedrop
# S3 (quando FILE_STORAGE_BACKEND=s3): template do bucket por tenant.
# `{tenant}` e substituido pelo tenant_id (primeiro segmento da key).
# Credenciais AWS pela cadeia padrao do botocore (env AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY) — SO no backend Strata, nunca no agente do cliente.
FILE_STORAGE_S3_BUCKET_TEMPLATE=
FILE_STORAGE_S3_REGION=sa-east-1
# Limites do gateway POST /api/v1/filedrop/upload.
FILEDROP_MAX_FILE_BYTES=26214400
FILEDROP_MAX_FILES_PER_REQUEST=200
