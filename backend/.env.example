# ---------- App ----------
APP_ENV=development
LOG_LEVEL=INFO

# ---------- Postgres (gr_db) ----------
DATABASE_URL=postgresql+asyncpg://gr_app:senha@host:5432/gr_db
DATABASE_ECHO=false

# Para pytest, aponte DATABASE_URL para gr_db_test (banco isolado, schema sincronizado
# via alembic). O guard em tests/conftest.py::pytest_configure aborta se o nome do
# banco nao contiver "test". Setup local:
#   1) CREATE DATABASE gr_db_test OWNER gr_app;
#   2) DATABASE_URL=...gr_db_test alembic upgrade head
#   3) DATABASE_URL=...gr_db_test pytest

# ---------- JWT ----------
# Gere uma chave forte: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000

# ---------- Integracoes: criptografia de secrets ----------
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_CONFIG_KEK=CHANGE_ME_TO_A_FERNET_KEY_URLSAFE_B64

# ---------- Scheduler ----------
# Intervalo do ciclo de sync Bitfin (minutos). Cada tenant com tenant_source_config
# habilitado e processado em sequencia. Credenciais de cada tenant vivem em
# tenant_source_config.config (JSONB) — NAO aqui.
BITFIN_SYNC_INTERVAL_MINUTES=30

# ---------- Credito: storage de anexos do dossie ----------
# Diretorio raiz onde os blobs de anexos do dossie sao gravados:
#   <root>/<tenant_id>/<dossier_id>/<sha256[:2]>/<sha256>
# Em dev: ./storage/dossier-attachments. Em prod: caminho absoluto fora do repo.
# Migracao para S3 fica em Fase 2 (swap implementacao do StorageBackend).
DOSSIER_STORAGE_ROOT=./storage/dossier-attachments
# Limite por upload em bytes (default 25 MB).
DOSSIER_ATTACHMENT_MAX_BYTES=26214400
